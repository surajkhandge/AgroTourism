@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />

    <style>

        body {
            font-family: Arial;
            padding: 40px;
            color: #333;
        }

        .invoice-box {
            max-width: 800px;
            margin: auto;
            border: 1px solid #eee;
            padding: 30px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

        /* Header css */
        .header-table {
            width: 100%;
            margin-bottom: 25px;
        }

            .header-table td {
                vertical-align: top;
            }

        .company-title {
            font-size: 26px;
            font-weight: bold;
            text-align: center;
        }

        .company-sub {
            text-align: center;
            color: #666;
        }

        /* Section css */
        .section-title {
            font-weight: bold;
            margin-top: 20px;
            margin-bottom: 8px;
        }

        /* css for table */
        .details-table {
            width: 100%;
            margin-bottom: 20px;
        }

            .details-table td {
                padding: 6px 0;
            }

        .invoice-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

            .invoice-table th {
                background: #f5f5f5;
                border: 1px solid #ddd;
                padding: 10px;
                text-align: left;
            }

            .invoice-table td {
                border: 1px solid #ddd;
                padding: 10px;
            }

        .text-right {
            text-align: right;
        }

        .total {
            font-weight: bold;
            font-size: 18px;
            color: #198754;
        }

        .footer {
            margin-top: 40px;
            text-align: center;
            color: #555;
            font-size: 14px;
        }
    </style>

</head>

<body>

    <div class="invoice-box">

        <!-- HEADER -->
        <table class="header-table">
            <tr>

                <td style="width:33%; text-align:left;">
                    <strong>Invoice No</strong><br />
                    @ViewBag.InvoiceNumber
                </td>

                <td style="width:34%;">
                    <div class="company-title">
                        AgroIndia Booking
                    </div>
                    <div class="company-sub">
                        Farmhouse Reservation Notice
                    </div>
                </td>

                <td style="width:33%; text-align:right;">
                    <strong>Date</strong><br />
                    @DateTime.Now.ToString("dd MMM yyyy hh:mm tt")
                </td>

            </tr>
        </table>

        <hr />

        <!-- DETAILS -->
        <table class="details-table">

            <tr>
                <td>
                    <div class="section-title">Payment Details</div>

                    <strong>Transaction ID:</strong><br />
                    @ViewBag.PaymentId<br /><br />

                    <strong>Payment Method:</strong><br />
                    @ViewBag.PaymentMethod
                </td>

                <td>
                    <div class="section-title">Booking Details</div>

                    <strong>Farmhouse:</strong><br />
                    @ViewBag.FarmHouse<br /><br />

                    <strong>Guests:</strong><br />
                    @ViewBag.NoOfGuest
                </td>
            </tr>

            <tr>
                <td>
                    <strong>Check-in:</strong><br />
                    @ViewBag.CheckinDate
                </td>

                <td>
                    <strong>Check-out:</strong><br />
                    @ViewBag.CheckoutDate
                </td>
            </tr>

        </table>

        <!-- BILL TABLE -->
        <table class="invoice-table">

            <tr>
                <th>Description</th>
                <th class="text-right">Amount</th>
            </tr>

            <tr>
                <td>Farmhouse Booking</td>
                <td class="text-right">₹ @String.Format("{0:N0}", ViewBag.Amount)</td>
            </tr>

            <tr>
                <td class="text-right total">Total Paid</td>
                <td class="text-right total">₹ @String.Format("{0:N0}", ViewBag.Amount)</td>
            </tr>

        </table>

        <!-- FOOTER -->
        <div class="footer">

            <p>
                Thank you for choosing <strong>AgroIndia</strong>.
            </p>

            <p>
                For support: support@agroindia.com
            </p>

        </div>

    </div>

</body>
</html>