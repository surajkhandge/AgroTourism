
@{
    ViewBag.Title = "TrustSafetyAG";
    Layout = "~/Views/Shared/Visitor.cshtml";
}

<!-- ================= COMMITMENT SECTION ================= -->
<section class="container mt-5 pt-5 mb-5">
    <h4 class="fw-bold">Our Commitment to Safety</h4>
    <p class="text-muted">Ensuring a secure and reliable experience for everyone.</p>

    <div class="row g-4 mt-3">

        <div class="col-md-4">
            <div class="safety-card text-center p-4">
                <i class="bi bi-shield-fill-check text-warning fs-2"></i>
                <h6 class="mt-3">Verified Profiles</h6>
                <p>All users undergo identity verification for enhanced trust and accountability.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="safety-card text-center p-4">
                <i class="bi bi-chat-dots-fill text-warning fs-2"></i>
                <h6 class="mt-3">Secure Messaging</h6>
                <p>Communicate safely with end-to-end encrypted messaging.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="safety-card text-center p-4">
                <i class="bi bi-hammer text-warning fs-2"></i> 
                <h6 class="mt-3">Dispute Resolution</h6>
                <p>Fair and impartial mediation services to resolve conflicts efficiently.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="safety-card text-center p-4">
                <i class="bi bi-lock-fill text-warning fs-2"></i>
                <h6 class="mt-3">Data Privacy</h6>
                <p>Your personal data is protected with industry-leading encryption.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="safety-card text-center p-4">
                <i class="bi bi-file-earmark-fill text-warning fs-2"></i>
                <h6 class="mt-3">Transparent Policies</h6>
                <p>Clear and accessible terms of service and privacy policies.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="safety-card text-center p-4">
                <i class="bi bi-telephone-fill text-warning fs-2"></i>
                <h6 class="mt-3">24/7 Support</h6>
                <p>Dedicated support team available around the clock.</p>
            </div>
        </div>

    </div>
</section>

<!-- ================= VERIFICATION SECTION ================= -->
<section class="container mb-5">
    <h4 class="fw-bold">Verification & Protection</h4>

    <div class="row g-4 mt-3">

        <div class="col-md-6">
            <div class="protection-card p-4">
                <h6 class="fw-bold mb-3">Verified Badges</h6>
                <p class="text-muted">Learn about the badges that signify trustworthiness.</p>

                <span class="badge bg-primary me-2 mb-2">Identity Verified</span>
                <span class="badge bg-success me-2 mb-2">Payment Secure</span>
                <span class="badge bg-danger me-2 mb-2">Trusted Host</span>
                <span class="badge bg-info me-2 mb-2">Community Trusted</span>

                <p class="mt-3 text-muted">
                    These badges help you identify reliable members and offerings.
                </p>
            </div>
        </div>

        <div class="col-md-6">
            <div class="protection-card p-4">
                <h6 class="fw-bold mb-3">Booking Protection</h6>

                <ul class="protection-list">
                    <li>
                        <i class="bi bi-check-circle text-success"></i>
                        <strong>Full Refund Guarantee</strong>
                        <p>Receive a full refund in case of significant issues.</p>
                    </li>
                    
                    <li>
                        <i class="bi bi-headset text-success"></i>
                        <strong>24/7 Emergency Support</strong>
                        <p>Immediate assistance for urgent issues.</p>
                    </li>

                    <li>
                        <i class="bi bi-house-check text-success"></i>
                        <strong>Host Reliability Check</strong>
                        <p>Regular monitoring of host performance.</p>
                    </li>
                </ul>

            </div>
        </div>

    </div>
</section>

<!-- ================= COMMUNITY GUIDELINES ================= -->
<section class="container mb-5">
    <h4 class="fw-bold">Community Guidelines</h4>
    <p class="text-muted">Building a welcoming and safe environment for everyone.</p>

    <div class="guideline-item">
        <i class="bi bi-heart text-success"></i>
        <div>
            <h6>Be Respectful</h6>
            <p>Treat all members with courtesy. Harassment or discrimination is not tolerated.</p>
        </div>
    </div>

    <div class="guideline-item">
        <i class="bi bi-shield-check custom-icon"></i>
        <div>
            <h6>Act Responsibly</h6>
            <p>Engage honestly and uphold your commitments.</p>
        </div>
    </div>

    <div class="guideline-item">
        <i class="bi bi-stars text-success"></i>
        <div>
            <h6>Maintain Authenticity</h6>
            <p>Ensure listings and profiles accurately represent offerings.</p>
        </div>
    </div>

    <div class="guideline-item">
        <i class="bi bi-flag text-success"></i>
        <div>
            <h6>Report Concerns</h6>
            <p>Notify us immediately if you encounter violations.</p>
        </div>
    </div>

</section>
