@model AgroClassLib.Visitor.BookingTP

<div class="modal fade"
     id="cancelBookingModal"
     tabindex="-1"
     aria-hidden="true"
     data-bs-backdrop="static"
     data-bs-keyboard="false">

    <div class="modal-dialog modal-lg modal-dialog-centered">

        <div class="modal-content shadow rounded-3">

            <!-- HEADER -->
            <div class="modal-header border-0">

                <h5 class="modal-title fw-bold">
                    Cancel Booking
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <!-- BODY -->
            <div class="modal-body px-4">

                <input type="hidden"
                       id="bookingCode"
                       value="@Model.BookingCode" />

                <p class="text-muted">
                    Are you sure you want to cancel this booking?
                    Please review the Booking & Cancellation Policy.
                </p>

                <!-- CANCELLATION POLICY -->

                <h6 class="fw-bold mt-3">
                    Cancellation Policy
                </h6>

                <div class="small text-muted mb-2" style="white-space:pre-line;">
                    @Model.BookingPolicy
                </div>

                <div class="small text-muted mb-3" style="white-space:pre-line;">
                    @Model.CancellationPolicy
                </div>

                <hr />

                <!-- REFUND DETAILS -->

                <h6 class="fw-bold">
                    Refund Details
                </h6>

                <p class="mb-1">
                    Total Paid :
                    <b>
                        ₹ @Model.TotalAmount.ToString("N2")
                    </b>
                </p>

                <p class="mb-1">
                    Refund Amount :
                    <b class="text-primary">
                        ₹ @Model.RefundedAmount.ToString("N2")
                    </b>
                </p>

                <p>
                    Refund Status :
                    <b class="text-success">
                        @Model.RefundStatus
                    </b>
                </p>

                <!-- ✅ NEW: CANCELLATION REASON -->

                <hr />

                <h6 class="fw-bold">
                    Cancellation Reason
                </h6>

                <div class="mb-3">
                    <textarea id="cancelReason"
                              class="form-control"
                              rows="3"
                              maxlength="250"
                              placeholder="Enter reason for cancellation..."></textarea>
                </div>

            </div>

            <!-- FOOTER -->

            <div class="modal-footer border-0">

                <button type="button"
                        class="btn btn-light border"
                        data-bs-dismiss="modal">
                    Keep Booking
                </button>

                <button type="button"
                        class="btn btn-danger px-4"
                        onclick="confirmCancelBooking()">
                    Confirm Cancellation
                </button>

            </div>

        </div>

    </div>

</div>
<script>
    function confirmCancelBooking() {
        var bookingCode = document.getElementById("bookingCode").value;
        var cancelReason = document.getElementById("cancelReason").value;

        if (!cancelReason.trim()) {
            Swal.fire({
                icon: 'warning',
                title: 'Required',
                text: 'Please enter a reason for cancellation.'
            });
            return;
        }

        // Disable button to prevent double click
        var btn = document.querySelector('.btn-danger');
        btn.disabled = true;
        btn.innerText = 'Processing...';

        $.ajax({
            url: '/Visitor/ConfirmCancelBookingTP',
            type: 'POST',
            data: {
                bookingCode: bookingCode,
                cancelReason: cancelReason
            },
            success: function (result) {
                if (result.success) {
                    // Close modal
                    $('#cancelBookingModal').modal('hide');

                    if (result.refund > 0 && result.razorpayRefund) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Booking Cancelled',
                            text: '₹' + result.refund + ' refund has been initiated successfully.'
                        }).then(function () {
                            location.reload();
                        });
                    } else if (result.refund > 0 && !result.razorpayRefund) {
                        Swal.fire({
                            icon: 'warning',
                            title: 'Booking Cancelled',
                            text: 'Booking cancelled but refund could not be processed automatically. Contact support.'
                        }).then(function () {
                            location.reload();
                        });
                    } else {
                        Swal.fire({
                            icon: 'info',
                            title: 'Booking Cancelled',
                            text: 'Your booking has been cancelled. No refund is applicable.'
                        }).then(function () {
                            location.reload();
                        });
                    }
                } else {
                    btn.disabled = false;
                    btn.innerText = 'Confirm Cancellation';
                    Swal.fire({
                        icon: 'error',
                        title: 'Failed',
                        text: 'Could not cancel booking. Please try again.'
                    });
                }
            },
            error: function () {
                btn.disabled = false;
                btn.innerText = 'Confirm Cancellation';
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'Something went wrong. Please try again.'
                });
            }
        });
    }
</script>