/* ===== PACKAGE SELECT ===== */

    function selectPackage(card) {

        let checkIn = $("#hdCheckIn").val();

        let checkOut = $("#hdCheckOut").val();

        if (!checkIn || !checkOut) {

            showToast("Select dates first", "warning");

            return;

        }

        $(".package-card").removeClass("package-selected");

        $(card).addClass("package-selected");

        selectedPackageName = $(card).data("name");

        selectedPrice = $(card).data("price");

        selectedDays = $(card).data("days");

        selectedNights = $(card).data("nights");
        selectedGuests = $(card).data("guests");

        showToast("Package Selected", "success");

    }

/* ===== PACKAGE VALIDATION ===== */
    function validatePackages() {

        let checkIn = $("#hdCheckIn").val();
        let checkOut = $("#hdCheckOut").val();

        if (!checkIn || !checkOut) {

            $(".package-card").css("opacity", "1");
            $(".package-card").css("pointer-events", "auto");

            return;

        }

        let start = new Date(convertToISO(checkIn));
        let end = new Date(convertToISO(checkOut));

        let nights = Math.ceil((end - start) / (1000 * 60 * 60 * 24));

        $(".package-card").each(function () {

            let pkgNights = parseInt($(this).data("nights"));

            if (pkgNights <= nights) {

                $(this).css("opacity", "1");
                $(this).css("pointer-events", "auto");

            }
            else {

                $(this).css("opacity", "0.35");
                $(this).css("pointer-events", "none");

            }

        });

    }

/* ===== BOOKING ===== */

function goToBooking(){

let checkIn=$("#hdCheckIn").val();
let checkOut=$("#hdCheckOut").val();
    if(!checkIn || !checkOut){showToast("Select dates","warning");return;}
    if (selectedPackageName == "") {showToast("Select package", "warning");return;}

let start=new Date(convertToISO(checkIn));
let nights=parseInt(selectedNights);
let newOut=new Date(start);
newOut.setDate(newOut.getDate()+nights);
let finalOut=newOut.toISOString().split('T')[0];
$.post('/Visitor/SetBookingSessionSK',{
farmCode:'@Model.FarmHouseCode',
packageName:selectedPackageName,
price:selectedPrice,
days:selectedDays,
nights:selectedNights,
guests:selectedGuests,
checkIn:convertToISO(checkIn),
checkOut: finalOut
},

function(){
window.location.href='/Visitor/GuestDetailsVH';});
}

