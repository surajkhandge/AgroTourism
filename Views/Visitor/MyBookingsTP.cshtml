@model List<AgroClassLib.Visitor.BookingTP>

@{
    ViewBag.Title = "My Bookings";
    Layout = "~/Views/Shared/Visitor.cshtml";


}<!-- Bootstrap -->
<!-- DataTables -->
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">

<!-- Responsive -->
<link rel="stylesheet" href="https://cdn.datatables.net/responsive/2.5.0/css/responsive.dataTables.min.css">

<!-- Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

<!-- Buttons -->
<link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.2/css/buttons.dataTables.min.css">
<style>

    #dataTable {
        border-radius: 10px;
        overflow: hidden;
    }

        #dataTable thead th {
            background: linear-gradient(90deg,#1f3b63,#2f5d9a);
            color: white;
            font-size: 15px;
        }


    /* DATATABLE EXPORT BUTTONS */

    .dt-buttons .dt-button {
        background: #fff !important;
        border: 2px solid #dee2e6 !important;
        border-radius: 6px;
        padding: 6px 12px;
        margin-right: 6px;
        font-weight: 600;
    }

    /* EXCEL */
    .dt-buttons .excelBtn {
        border: 2px solid #198754 !important;
        color: #198754 !important;
    }

        .dt-buttons .excelBtn:hover {
            background: #198754 !important;
            color: #fff !important;
        }

    /* PDF */
    .dt-buttons .pdfBtn {
        border: 2px solid #dc3545 !important;
        color: #dc3545 !important;
    }

        .dt-buttons .pdfBtn:hover {
            background: #dc3545 !important;
            color: #fff !important;
        }

    /* PRINT */
    .dt-buttons .printBtn {
        border: 2px solid #6c757d !important;
        color: #6c757d !important;
    }

        .dt-buttons .printBtn:hover {
            background: #6c757d !important;
            color: #fff !important;
        }

    /* TABS CONTAINER */

    .nav-tabs {
        border-bottom: 2px solid #2f5d9a;
        gap: 8px;
    }

        /* FIX TAB FADE ISSUE */

        .nav-tabs .nav-link {
            opacity: 1 !important;
            background-color: #f4f6fa !important;
            color: #1f3b63 !important;
            border: 1px solid #cfd6e0 !important;
            font-weight: 600;
        }

            /* HOVER */

            .nav-tabs .nav-link:hover {
                background-color: #e6edff !important;
                color: #1f3b63 !important;
            }

            /* ACTIVE TAB */

            .nav-tabs .nav-link.active {
                background-color: #2f5d9a !important;
                color: #ffffff !important;
                border-color: #2f5d9a !important;
                box-shadow: 0 3px 8px rgba(0,0,0,0.15);
            }

            /* REMOVE BOOTSTRAP DISABLED STYLE */

            .nav-tabs .nav-link.disabled {
                opacity: 1 !important;
                color: #1f3b63 !important;
            }

            /* REMOVE CLICK OUTLINE */

            .nav-tabs .nav-link:focus {
                box-shadow: none;
            }

    /* REMOVE SPACE BETWEEN DATE FILTER AND SEARCH */

    .dataTables_wrapper .dataTables_filter {
        margin-left: 0 !important;
        padding-left: 0 !important;
    }

    #dateFilterBox {
        margin-right: 0 !important;
    }

        #dateFilterBox button {
            margin-left: 2px !important;
        }

    /* remove datatable default spacing */
    .dataTables_wrapper .dt-buttons {
        margin-right: 6px !important;
    }

    .dataTables_wrapper .dataTables_filter input {
        margin-left: 4px !important;
    }

    /* force everything in one line */
    .dataTables_wrapper .d-flex {
        align-items: center;
        gap: 6px;
    }

    #dataTable {
        border-radius: 10px;
        overflow: hidden;
        border-collapse: collapse;
        width: 100%;
    }

        #dataTable tbody tr {
            height: 50px;
        }

            #dataTable tbody tr:hover {
                background-color: #f4f7fb;
            }
</style>

<div class="container mt-5">
    <input type="hidden" id="visitorCode" value="@Session["VisitorCode"]" />

    <div class="card shadow-lg border-0">
        <div class="card-body">

            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="fw-bold mb-0">Billing & Booking Records</h4>
            </div>

            <!-- TABS -->
            <div class="d-flex justify-content-between align-items-center mb-3">

                <!-- LEFT SIDE TABS -->
                <ul class="nav nav-tabs border-0">

                    <li class="nav-item">
                        <a href="@Url.Action("UpcomingBookingTP","Visitor")"
                           onclick="refreshTable()"
                           class="nav-link @(ViewBag.ActiveTab=="UpcomingTripsTP" ? "active" : "")">
                            Upcoming Trips
                        </a>
                    </li>

                    <li class="nav-item">
                        <a href="@Url.Action("BookingHistoryTP","Visitor")"
                           onclick="refreshTable()"
                           class="nav-link @(ViewBag.ActiveTab=="BookingHistoryTP" ? "active" : "")">
                            Booking History
                        </a>
                    </li>

                    <li class="nav-item">
                        <a href="@Url.Action("CancelledBookingsTP","Visitor")"
                           onclick="refreshTable()"
                           class="nav-link @(ViewBag.ActiveTab=="CancelledBookingsTP" ? "active" : "")">
                            Cancelled Bookings
                        </a>
                    </li>

                </ul>

                <!-- RIGHT SIDE FILTER -->
                <div class="d-flex align-items-center gap-2" id="dateFilterBox">

                    <span>From</span>
                    <input type="date"
                           id="fromDate"
                           class="form-control form-control-sm"
                           style="width:150px"
                           onchange="filterTable()">

                    <span>To</span>
                    <input type="date"
                           id="toDate"
                           class="form-control form-control-sm"
                           style="width:150px"
                           onchange="filterTable()">

                    <button class="btn btn-outline-primary btn-sm"
                            onclick="refreshTable()">
                        <i class="fa fa-rotate-right"></i>
                    </button>

                </div>

            </div>

            <!-- TABLE -->
            <div class="table-responsive">
                <table id="dataTable"
                       class="table table-bordered align-middle display "
                       style="width:100%">

                    <thead class="table-light">
                        <tr>

                            <th>
                                <input type="checkbox" id="selectAll">
                            </th>

                            <th>Sr No</th>
                            <th>FarmHouse</th>
                            <th class="checkinCol">Check-In</th>
                            <th class="checkoutCol">Check-Out</th>
                            <th>Total Amount</th>
                            <th>Status</th>
                            <th>Action</th>

                        </tr>
                    </thead>

                    <tbody>

                        @{
                            int sr = 1;
                        }

                        @foreach (var item in Model)
                        {
                            <tr>

                                <td>
                                    <input type="checkbox"
                                           class="rowCheckbox"
                                           value="@item.BookingCode">
                                </td>

                                <td>@sr</td>

                                @Html.Hidden("FarmHouseCode", item.FarmHouseCode)

                                <td>@item.FarmHouseName</td>
                                <td>@item.CheckinDate.ToString("dd-MM-yyyy")</td>
                                <td>@item.CheckoutDate.ToString("dd-MM-yyyy")</td>
                                <td>₹ @item.TotalAmount</td>
                                <td>@item.StatusName</td>

                                <td>

                                    <button type="button"
                                            class="btn btn-outline-warning btn-rounded btn-sm"
                                            onclick="openBookingDetails('@item.BookingCode')">

                                        <i class="fa fa-eye"></i> View Booking
                                    </button>

                                    @if (item.StatusName == "Cancelled" || item.StatusName == "Completed")
                                    {
                                        <button type="button"
                                                class="btn btn-outline-danger btn-rounded btn-sm ms-2"
                                                disabled>

                                            <i class="fa fa-times"></i> Cancel Booking
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button"
                                                class="btn btn-outline-danger btn-rounded btn-sm ms-2"
                                                onclick="openCancelPopup('@item.BookingCode')">

                                            <i class="fa fa-times"></i> Cancel Booking
                                        </button>
                                    }

                                </td>
                            </tr>

                            sr++;
                        }

                    </tbody>
                </table>
            </div>

        </div>
    </div>

</div>


<!-- BOOKING DETAILS MODAL -->
<div class="modal fade" id="bookingDetailsModal">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Booking Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body" id="bookingDetailsBody">
            </div>

        </div>
    </div>
</div>

<div id="cancelBookingModalContainer"></div>

<!-- jQuery (FIRST) -->
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>



<!-- DataTables -->
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

<!-- Responsive -->
<script src="https://cdn.datatables.net/responsive/2.5.0/js/dataTables.responsive.min.js"></script>

<!-- Buttons -->
<script src="https://cdn.datatables.net/buttons/2.4.2/js/dataTables.buttons.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.html5.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.print.min.js"></script>

<!-- Export dependencies -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>

<!--Sweet Alert for confirm cancel-->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

@*@RenderSection("scripts", required: false)*@


<script>
    var table;
    $(document).ready(function () {

        table = $('#dataTable').DataTable({

            pageLength: 10,
            ordering: false,
            responsive: false,
            lengthChange: false,

            dom: '<"d-flex justify-content-between mb-2"Bf>rtip',

            buttons: [

                // ================= EXCEL =================
                {
                    extend: 'excelHtml5',
                    text: ' <i class="fa fa-file-excel"></i>',
                    className: 'btn excelBtn btn-outline-success',

                    title: 'My Bookings',
                    messageTop: 'Generated on: ' + new Date().toLocaleString(),

                    exportOptions: {
                        columns: [1, 2, 3, 4, 5, 6],
                        rows: function (idx, data, node) {
                            return $(node).find('.rowCheckbox').prop('checked');
                        }
                    },

                    customizeData: function (data) {

                        for (var i = 0; i < data.body.length; i++) {
                            data.body[i][0] = i + 1;
                        }

                    },

                    action: function (e, dt, button, config) {

                        if ($('.rowCheckbox:checked').length === 0) {

                            Swal.fire({
                                icon: 'warning',
                                title: 'Select Row',
                                text: 'Please select at least one booking.'
                            });

                            setTimeout(() => {
                                Swal.close()
                            }, 1000);

                            return;
                        }

                        $.fn.dataTable.ext.buttons.excelHtml5.action.call(this, e, dt, button, config);

                        Swal.fire({
                            icon: 'success',
                            title: 'Excel Downloaded',
                            text: 'Selected bookings exported successfully.'
                        });

                        setTimeout(() => {
                            Swal.close()
                        }, 1000);
                    }
                },


                // ================= PDF =================
                {
                    extend: 'pdfHtml5',
                    text: '<i class="fa fa-file-pdf"></i>',
                    className: 'btn pdfBtn btn-outline-danger',

                    title: 'My Bookings',
                    messageTop: 'Generated on: ' + new Date().toLocaleString(),

                    exportOptions: {
                        columns: [1, 2, 3, 4, 5, 6],
                        rows: function (idx, data, node) {
                            return $(node).find('.rowCheckbox').prop('checked');
                        },

                        format: {
                            body: function (data, row, column, node) {

                                if (column === 0) {
                                    return row + 1;
                                }

                                return data;
                            }
                        }
                    },

                    customize: function (doc) {

                        if (doc.content && doc.content[1] && doc.content[1].table) {

                            doc.content[1].table.widths = ['10%', '25%', '15%', '15%', '15%', '20%'];

                            for (var i = 1; i < doc.content[1].table.body.length; i++) {
                                doc.content[1].table.body[i][0].text = i;
                            }
                        }
                    },

                    action: function (e, dt, button, config) {

                        if ($('.rowCheckbox:checked').length === 0) {

                            Swal.fire({
                                icon: 'warning',
                                title: 'Select Row',
                                text: 'Please select at least one booking.'
                            });
                            setTimeout(() => {
                                Swal.close()
                            }, 1000);

                            return;
                        }

                        $.fn.dataTable.ext.buttons.pdfHtml5.action.call(this, e, dt, button, config);

                        Swal.fire({
                            icon: 'success',
                            title: 'PDF Downloaded',
                            text: 'Selected bookings exported successfully.'
                        });

                        setTimeout(() => {
                            Swal.close()
                        }, 1000);
                    }
                },


                // ================= PRINT =================
                {
                    extend: 'print',
                    text: '<i class="fa-solid fa-print"></i>',
                    className: 'btn printBtn btn-outline-secondary',

                    title: 'My Bookings',
                    messageTop: 'Generated on: ' + new Date().toLocaleString(),

                    exportOptions: {
                        columns: [1, 2, 3, 4, 5, 6],
                        rows: function (idx, data, node) {
                            return $(node).find('.rowCheckbox').prop('checked');
                        }
                    },

                    customize: function (win) {

                        $(win.document.body).find('table tbody tr').each(function (index) {

                            $(this).find('td:eq(0)').text(index + 1);

                        });

                    },

                    action: function (e, dt, button, config) {

                        if ($('.rowCheckbox:checked').length === 0) {

                            Swal.fire({
                                icon: 'warning',
                                title: 'Select Row',
                                text: 'Please select at least one booking.'
                            });

                            setTimeout(() => {
                                Swal.close()
                            }, 1000);

                            return;
                        }

                        $.fn.dataTable.ext.buttons.print.action.call(this, e, dt, button, config);

                        Swal.fire({
                            icon: 'success',
                            title: 'Print Ready',
                            text: 'Selected bookings ready to print.'
                        });

                        setTimeout(() => {
                            Swal.close()
                        }, 1000);

                    }
                }

            ],
            language: {
                search: "",
                searchPlaceholder: "Search bookings..."
            }

        });


        // DATE FILTER REGISTER
        $.fn.dataTable.ext.search.push(function (settings, data, dataIndex) {

            var from = $("#fromDate").val();
            var to = $("#toDate").val();

            var checkInIndex = table.column('.checkinCol').index();
            var checkOutIndex = table.column('.checkoutCol').index();

            var checkIn = data[checkInIndex];
            var checkOut = data[checkOutIndex];

            if (!checkIn || !checkOut) return true;

            function parseDate(dateStr) {
                var parts = dateStr.split("-");
                return new Date(parts[2], parts[1] - 1, parts[0]);
            }

            var checkInDate = parseDate(checkIn);
            var checkOutDate = parseDate(checkOut);

            var fromDate = from ? new Date(from) : null;
            var toDate = to ? new Date(to) : null;

            if (fromDate && checkOutDate < fromDate) return false;
            if (toDate && checkInDate > toDate) return false;

            return true;

        });

    });


    // SELECT ALL CHECKBOX

    $("#selectAll").click(function () {

        $(".rowCheckbox").prop("checked", this.checked);

    });

    $(document).on("click", ".rowCheckbox", function () {

        if ($(".rowCheckbox:checked").length == $(".rowCheckbox").length) {
            $("#selectAll").prop("checked", true);
        } else {
            $("#selectAll").prop("checked", false);
        }

    });

    // VIEW BOOKING DETAILS MODAL

    function openBookingDetails(bookingCode, farmHouseCode) {

        var visitorCode = $("#visitorCode").val();

        $.ajax({
            url: '/Visitor/BookingDetailsTP',
            type: 'GET',
            data: {
                bookingCode: bookingCode,
                farmHouseCode: farmHouseCode
            },
            success: function (data) {

                $("#bookingDetailsBody").html(data);

                var modal = new bootstrap.Modal(
                    document.getElementById('bookingDetailsModal')
                );

                modal.show();
            },
            error: function () {
                alert("Booking details load failed");
            }
        });

    }
    // CANCEL BOOKING MODAL
    function openCancelPopup(bookingCode) {

        $.ajax({

            url: '/Visitor/CancelBookingTP',

            type: 'GET',

            data: {
                bookingCode: bookingCode
            },

            success: function (data) {

                $("#cancelBookingModalContainer").html(data);

                var modal =
                    new bootstrap.Modal(
                        document.getElementById('cancelBookingModal'));

                modal.show();

            },

            error: function () {

                Swal.fire(
                    "Error",
                    "Cancel booking load failed",
                    "error");

                setTimeout(() => {
                    Swal.close()
                }, 1000);

            }


        });

    }

    // confirm cancel bookings
    function confirmCancelBooking() {

        var bookingCode = $("#bookingCode").val();
        var cancelReason = $("#cancelReason").val().trim();
        if (cancelReason === "") {
            Swal.fire("Validation", "Please enter cancellation reason", "warning");
            return;
        }
        if (cancelReason.length < 10) {
            Swal.fire("Validation", "Reason must be at least 10 characters", "warning");
            return;
        }
        var validText = /^[A-Za-z\s.,'-]+$/;

        if (!validText.test(cancelReason)) {
            Swal.fire("Validation", "Please enter a valid reason (alphabets only)", "warning");
            return;
        }
        if (cancelReason.split(" ").length < 2) {
            Swal.fire("Validation", "Please enter a proper reason (at least 2 words)", "warning");
            return;
        }

        $.ajax({
            url: '/Visitor/ConfirmCancelBookingTP',
            type: 'POST',
            data: {
                bookingCode: bookingCode,
                cancelReason: cancelReason
            },

            success: function (response) {

                if (response.success) {

                    var modal = bootstrap.Modal.getInstance(
                        document.getElementById('cancelBookingModal')
                    );

                    modal.hide();

                    Swal.fire({
                        icon: 'success',
                        title: 'Cancelled!',
                        text: 'Booking cancelled successfully.',
                        confirmButtonColor: '#3085d6',
                        confirmButtonText: 'OK'
                    }).then((result) => {

                        if (result.isConfirmed) {
                            location.reload();
                        }

                    });

                }
            },

            error: function () {

                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'Cancellation failed!'
                });

            }

        });

    }

    // DATE FILTER FUNCTION
    function filterTable() {
        table.draw();
    }


    // REFRESH BUTTON FUNCTION
    function refreshTable() {

        // clear date filters
        $("#fromDate").val("");
        $("#toDate").val("");

        // clear datatable search
        table.search('').columns().search('');

        // uncheck all checkboxes
        $("#selectAll").prop("checked", false);
        $(".rowCheckbox").prop("checked", false);

        // redraw table
        table.draw();

    }
    // move date filter beside search boxR

    setTimeout(function () {

        var filter = $(".dataTables_filter");

        $("#dateFilterBox").insertBefore(filter);

    }, 200);


    document.querySelectorAll('.dropdown-toggle')
        .forEach(function (drop) {
            new bootstrap.Dropdown(drop);
        });

</script>
