
@model List<AgroClassLib.Visitor.VisitorSK>
@{
    ViewBag.Title = "FilterFarmhousesSK";
    Layout = "~/Views/Shared/Visitor.cshtml";
}

<style>
    /* PAGE LAYOUT */
    .listing-wrapper {
        display: flex;
        gap: 30px;
        padding: 30px;
    }

    /* FILTER SIDEBAR */
    .filter-sidebar {
        background: #f8f9fa;
        padding: 20px;
        border-radius: 10px;
        position: sticky;
        top: 100px;
    }

    /* PRICE TEXT */
    .active-price {
        font-weight: 600;
        color: #2f5d50;
    }

    #priceRange {
        width: 100%;
        height: 6px;
        border-radius: 5px;
        outline: none;
        appearance: none;
        -webkit-appearance: none;
        background: linear-gradient(to right,#2d6a4f 0%,#2d6a4f 50%,#dcdcdc 50%,#dcdcdc 100%);
    }

        /* Chrome */
        #priceRange::-webkit-slider-runnable-track {
            height: 6px;
            border-radius: 5px;
            background: transparent;
        }

        /* Chrome thumb */
        #priceRange::-webkit-slider-thumb {
            appearance: none;
            -webkit-appearance: none;
            width: 18px;
            height: 18px;
            background: #2d6a4f;
            border-radius: 50%;
            cursor: pointer;
            margin-top: -6px;
            border: 2px solid white;
            box-shadow: 0 0 3px rgba(0,0,0,0.3);
        }

        /* Firefox */
        #priceRange::-moz-range-track {
            background: transparent;
        }

        #priceRange::-moz-range-thumb {
            width: 18px;
            height: 18px;
            background: #2d6a4f;
            border-radius: 50%;
            cursor: pointer;
            border: none;
        }
</style>

<div class="container-fluid mt-4">

    <div class="row">

        <!-- LEFT FILTER -->
        <div class="col-lg-3 col-md-4 mb-4">

            <div class="filter-sidebar">

                <h4 class="mb-4">Filters</h4>

                <label class="fw-semibold mb-3">Price Range</label>

                <div class="d-flex justify-content-between mb-2">
                    <span>₹500</span>
                    <span class="active-price">
                        ₹<span id="selectedPrice">5000</span>
                    </span>
                    <span>₹10000</span>
                </div>

                <input type="range"
                       id="priceRange"
                       min="500"
                       max="10000"
                       step="500"
                       value="10000"
                       class="form-range">

                <hr>

                <label class="fw-semibold mb-2">Minimum Rating</label>

                <div class="form-check">
                    <input type="radio" name="rating" value="4.5" class="form-check-input">
                    <label class="form-check-label">4.5+ Stars</label>
                </div>

                <div class="form-check">
                    <input type="radio" name="rating" value="4" class="form-check-input">
                    <label class="form-check-label">4+ Stars</label>
                </div>

                <div class="form-check">
                    <input type="radio" name="rating" value="3" class="form-check-input">
                    <label class="form-check-label">3+ Stars</label>
                </div>

                <button id="clearFilters"
                        class="btn btn-outline-secondary w-100 mt-4">
                    Clear Filters
                </button>

            </div>

        </div>

        <!-- RIGHT LISTING -->
        <div class="col-lg-9 col-md-8">

            <div class="container">

                <div id="farmhouseContainer">

                    <div class="row g-4">

                        @Html.Partial("FarmHousesListSK", Model)

                    </div>

                </div>

            </div>

        </div>
    </div>

</div>

<script>

    $(document).ready(function () {

        // Initial slider color
        updateSliderBackground($("#priceRange").val());

        // Price slider change
        $("#priceRange").on("input change", function () {

            let price = $(this).val();

            $("#selectedPrice").text(price);

            updateSliderBackground(price);

            applyFilters();

        });

        // Rating change
        $("input[name='rating']").change(function () {

            applyFilters();

        });

        // Clear filters
        $("#clearFilters").click(function () {

            $("#priceRange").val(10000);

            $("#selectedPrice").text(10000);

            $("input[name='rating']").prop("checked", false);

            updateSliderBackground(10000);

            // important
            applyFilters();

        });

    });


    function updateSliderBackground(value) {

        let min = 500;

        let max = 10000;

        let percent = ((value - min) / (max - min)) * 100;

        document.getElementById("priceRange").style.background =
            "linear-gradient(to right,#2d6a4f 0%,#2d6a4f " + percent + "%,#dcdcdc " + percent + "%,#dcdcdc 100%)";

    }


  function applyFilters() {

let maxPrice=$("#priceRange").val();

let minRating=$("input[name='rating']:checked").val();

let cityId='@(ViewBag.CityId ?? "")';

if(cityId==="" || cityId==="undefined")
cityId=null;

$.ajax({

url:'/Visitor/FilterFarmhousesSK',

type:'GET',

    data: {
        cityId: cityId || null,
        maxPrice: maxPrice || null,
        minRating: minRating || null
    },

success:function(result){

$("#farmhouseContainer").html(result);

}

});

}

</script>