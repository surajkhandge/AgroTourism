@model AgroClassLib.Visitor.ConfirmBookingVM

@{
    ViewBag.Title = "Confirm Booking";
    Layout = "~/Views/Shared/Visitor.cshtml";
}
<style>
    .booksummrybox {
        padding-top: 50px;
        padding-bottom: 50px;
    }

    .card:hover,
    .container:hover,
    .room-card:hover {
        box-shadow: none !important;
        transform: none !important;
        transition: none !important;
    }
</style>
<div class="container booksummrybox mt-5 mb-5">

    <div class="card shadow p-4" style="border-radius:10px;">

        <h3 class="fw-bold mb-1">
            Confirm Booking Summary
        </h3>

        <p class="text-muted">
            Please review your booking details before confirming.
        </p>

        <hr />

        <!-- FARM DETAILS -->

        <h5 class="fw-bold">Farmhouse Details</h5>

        <div class="row">

            <div class="col-md-6">

                <div class="text-muted">Farmhouse</div>

                <div class="fw-bold">
                    @Model.FarmHouseName
                </div>

            </div>

            <div class="col-md-6 text-end">

                <div class="text-muted">Location</div>

                <div class="fw-bold">
                    @Model.Location
                </div>

            </div>

        </div>

        <hr />

        <!-- VISIT -->

        <h5 class="fw-bold">Visit Dates</h5>

        <div class="row text-center">

            <div class="col-md-4">

                <div class="text-muted">Check-in</div>

                <div class="fw-bold">
                    @Model.CheckIn.ToString("dd MMM yyyy")
                </div>

            </div>

            <div class="col-md-4">

                <div class="text-muted">Check-out</div>

                <div class="fw-bold">
                    @Model.CheckOut.ToString("dd MMM yyyy")
                </div>

            </div>

            <div class="col-md-4">

                <div class="text-muted">Total Nights</div>

                <div class="fw-bold">
                    @Model.Nights
                </div>

            </div>

        </div>

        <hr />

        <!-- PACKAGE -->

        @if (Model.IsPackageBooking)
        {

            <h5 class="fw-bold">Package Details</h5>

            <div class="mb-3">

                <div class="fw-bold text-success">
                    @Model.PackageName
                </div>

                <div class="text-muted">
                    @Model.Nights Nights
                </div>

            </div>

            <table class="table">

                <tr>
                    <td width="30%">Room Type</td>

                    <td>
                        @Model.RoomTypeName
                        <span class="text-muted">(Included in package)</span>
                    </td>

                </tr>

                <tr>

                    <td>Meals</td>

                    <td>
                        @Model.MealTypeName
                    </td>

                </tr>

                <tr>

                    <td>Activities</td>

                    <td>

                        @foreach (var act in Model.Activities)
                        {
                            <div>@act.ActivityServiceName</div>
                        }

                    </td>

                </tr>

            </table>

        }
        else
        {

            <h5 class="fw-bold">Rooms Selected</h5>

            <table class="table">

                <thead>

                    <tr>
                        <th>Room</th>

                        <th>Qty</th>

                        <th class="text-end">Price</th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var room in Model.Rooms)
                    {

                        <tr>

                            <td>
                                @room.RoomTypeName
                            </td>

                            <td>
                                @room.Quantity
                            </td>

                            <td class="text-end">

                                Rs @(room.PricePerNight * room.Quantity)

                            </td>

                        </tr>

                    }

                </tbody>

            </table>


            <h5 class="fw-bold">Activities</h5>

            <table class="table">

                <thead>

                    <tr>

                        <th>Activity</th>

                        <th class="text-end">Price</th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var act in Model.Activities)
                    {

                        <tr>

                            <td>
                                @act.ActivityServiceName
                            </td>

                            <td class="text-end">

                                Rs @act.Price

                            </td>

                        </tr>

                    }

                </tbody>

            </table>

        }
        <hr />

        <!-- PRICE -->

        @if (Model.IsPackageBooking)
        {

            <h5 class="fw-bold">Price Summary</h5>

            <table class="table">

                <tr>

                    <td>Package Price</td>

                    <td>
                        ₹@Model.PackagePrice
                    </td>

                </tr>

                <tr>

                    <td>

                        Discount (@Model.DiscountPercent%)

                    </td>

                    <td class="text-danger">

                        - ₹@Model.DiscountAmount

                    </td>

                </tr>

                <tr class="fw-bold">

                    <td>Final Amount</td>

                    <td class="text-success">

                        ₹@Model.FinalPrice

                    </td>

                </tr>

            </table>

        }
        else
        {

            <h5>Total Cost</h5>

            <h4 class="text-success">

                Rs @Model.TotalCost

            </h4>

        }
        <!--<hr />-->
        <!-- PAYMENT -->
        <!--<h5 class="fw-bold">Payment</h5>

        <div class="text-muted">

            Payment Mode : Pay at Property

        </div>-->
        <!--<hr />-->

        <div class="d-flex justify-content-end">

            <a href="@Url.Action("FarmDetailsSK","Visitor",
                        new { id = Model.FarmHouseCode })"
               class="btn btn-outline-danger btn-rounded me-2">

                <i class="fa fa-times"></i>
                Cancel

            </a>

            <a id="payBtn" class="btn btn-outline-success btn-rounded px-4" onclick="startPayment()">
                <i class="fas fa-check"></i>
                Confirm Booking
            </a>

        </div>

    </div>

</div>
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
function showLoading(title, message) {
    title = title || 'Processing';
    message = message || 'Please wait';
    Swal.fire({
        html: `
            <div style="display:flex;flex-direction:column;align-items:center;padding:25px;">
                <div style="width:50px;height:50px;border-radius:50%;border:5px solid #25b09b;border-top-color:transparent;animation:spin 1s linear infinite;"></div>
                <div style="font-size:20px;font-weight:600;color:#1b4332;margin-top:15px;">${title}</div>
                <div style="color:#666;font-size:14px;">${message}</div>
            </div>
            <style>@@keyframes spin{to{transform:rotate(360deg)}}</style>
        `,
        showConfirmButton: false,
        allowOutsideClick: false,
        background: '#ffffff',
        width: 400,
        padding: 0,
        customClass: { popup: 'modern-popup' }
    });
}


        var bookingData = {
        FarmHouseName: '@Model.FarmHouseName',
        FarmHouseCode: '@Model.FarmHouseCode',
        CheckinDate: '@Model.CheckIn.ToString("yyyy-MM-dd")',
        CheckoutDate: '@Model.CheckOut.ToString("yyyy-MM-dd")',
        NoOfGuest: @Model.NoOfGuest,
        TotalAmount: @(Model.IsPackageBooking ? Model.FinalPrice : Model.TotalCost),

    };
    async function startPayment() {
        var btn = document.getElementById("payBtn");
        btn.disabled = true;

        showLoading("Preparing Payment", "Connecting to Gateway");

        try {

            const sessionRes = await fetch('/Visitor/PreparePaymentSession', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(bookingData)
            });

            const sessionResult = await sessionRes.json();

            if (!sessionResult.success) {
                Swal.close();
                throw new Error("Session setup failed");
            }

            const orderRes = await fetch('/Visitor/CreateOrderST', { method: 'POST' });

            if (!orderRes.ok) throw new Error("Order creation failed");

            const data = await orderRes.json();

            Swal.close();

            var options = {

                key: "rzp_test_SKJffluQb0FxhL",

                amount: data.Amount,

                currency: "INR",

                order_id: data.OrderId,

                method: {
                    upi: true,
                    card: true,
                    netbanking: true,
                    wallet: false,
                    emi: false,
                    paylater: false
                },

                prefill: {
                    name: "Test User",
                    email: "test@test.com",
                    contact: "9123456789"
                },

                handler: function (response) {
                    //console.log(response);
                    showLoading("Verifying Payment", "Please Wait");

                    fetch('/Visitor/VerifyPaymentST', {

                        method: 'POST',

                        headers: { 'Content-Type': 'application/json' },

                        body: JSON.stringify({
                            RazorpayOrderId: response.razorpay_order_id,
                            RazorpayPaymentId: response.razorpay_payment_id,
                            RazorpaySignature: response.razorpay_signature
                        })

                    })

                        .then(function (res) {
                            if (!res.ok) throw new Error("Verfication failed");
                            return res.json();
                        })

                        .then(function (result) {

                            Swal.close();

                            if (result.success) {
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Payment Successful',
                                    text: 'Your booking has been confirmed Thank you for choosing us',
                                    confirmButtonColor: '#1b4332'
                                }).then(function () {
                                    window.location.href = "/Visitor/PaymentSuccessST"
                                });
                            }
                            else {
                                btn.disabled = false;
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Payment Failed',
                                    text: 'Your payment could not be verified.',
                                    confirmButtonText: 'Try again'
                                });
                            }
                        })
                        .catch(function () {
                            Swal.close();
                            btn.disabled = false;
                            Swal.fire({
                                icon: 'error',
                                title: 'Verification Error',
                                text: 'Something went wrong during verification. Contact support.'
                            });
                        });
                },

                modal: {
                    ondismiss: function () {
                        btn.disabled = false;
                        Swal.fire({
                            icon: 'warning',
                            title: 'Payment Cancelled',
                            text: 'You closed the payment window.'
                        });
                    }

                }
            };

            var rzp = new Razorpay(options);

            rzp.on('payment.failed', function (response) {
                btn.disabled = false;
                Swal.fire({
                    icon: 'error',
                    title: 'Payment Failed',
                    text: response.error.description || 'Payment was not completed.'
                });
            });

            rzp.open();

        } catch (error) {

            Swal.close();
            btn.disabled = false;

            Swal.fire({
                icon: 'error',
                title: 'Something Went Wrong',
                text: error.message|| 'Unable to initiate payment'
            });
        }
    }


</script>