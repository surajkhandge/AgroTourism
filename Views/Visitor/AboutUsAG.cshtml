@{
    ViewBag.Title = "About Us";
    Layout = "~/Views/Shared/Visitor.cshtml";
}
<!-- ================= HERO BANNER ================= -->
<section class="about-hero">
    <div class="about-overlay"></div>
    <div class="container text-center text-white about-hero-content">
        <h2 class="fw-bold">Growing Together, Naturally</h2>
        <p class="mt-3">
            Farmhouse is dedicated to fostering genuine connections and
            sustainable living, inspired by simplicity and beauty of nature.
        </p>
    </div>
</section>

<!-- ================= MISSION ================= -->
<section class="container py-5">
    <h4 class="section-title mb-4">Our Mission</h4>

    <div class="row align-items-center">
        <div class="col-lg-8">
            <p>
                At Farmhouse, our mission is to empower communities to discover and connect
                with unique, locally-sourced products and experiences. We believe in nurturing
                a marketplace where transparency, quality, and sustainability are paramount.
                We strive to bridge the gap between conscious consumers and passionate producers,
                fostering a symbiotic relationship that benefits all.
            </p>

            <p>
                We are committed to building a platform that not only facilitates commerce
                but also cultivates a deeper appreciation for craftsmanship and the environment.
                By prioritizing ethical practices and embracing innovative solutions,
                we aim to inspire a movement towards a more mindful and connected world.
            </p>
        </div>

        <div class="col-lg-4 text-center">
            <div class="mission-image-box">
                <img src="https://cdn-icons-png.flaticon.com/512/4284/4284039.png"
                     class="img-fluid"
                     alt="Community Image" />
            </div>
        </div>
    </div>
</section>

<!-- ================= TEAM ================= -->
<section class="container py-5">
    <h4 class="section-title mb-4">Meet Our Team</h4>

    <div class="row g-4 text-center">

        <div class="col-lg-3 col-md-6">
            <div class="team-card">
                <img src="https://randomuser.me/api/portraits/women/65.jpg" class="team-img" />
                <h6 class="mt-3">Shruti Patil</h6>
                <small>CEO & Founder</small>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="team-card">
                <img src="https://randomuser.me/api/portraits/men/45.jpg" class="team-img" />
                <h6 class="mt-3">Jay Shinde</h6>
                <small>Chief Technology Officer</small>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="team-card">
                <img src="https://randomuser.me/api/portraits/men/12.jpg" class="team-img" />
                <h6 class="mt-3">Gaurav Sutar</h6>
                <small>Head of Product</small>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="team-card">
                <img src="https://randomuser.me/api/portraits/men/77.jpg" class="team-img" />
                <h6 class="mt-3">Anubhav Bandgar</h6>
                <small>Marketing Director</small>
            </div>
        </div>

    </div>
</section>

<!-- ================= VALUES ================= -->
<section class="container py-5">
    <h4 class="section-title mb-4">Our Values</h4>

    <div class="row g-4">

        <div class="col-lg-4 col-md-6">
            <div class="value-card">
                <i class="bi bi-recycle"></i>
                <h6>Sustainability</h6>
                <p>We champion environmentally friendly practices, supporting producers who prioritize the health of our planet.</p>
            </div>
        </div>

        <div class="col-lg-4 col-md-6">
            <div class="value-card">
                <i class="bi bi-people"></i>
                <h6>Community</h6>
                <p>Fostering strong connections between individuals and local businesses, building a network of trust and mutual support.</p>
            </div>
        </div>

        <div class="col-lg-4 col-md-6">
            <div class="value-card">
                <i class="bi bi-heart"></i>
                <h6>Integrity</h6>
                <p>Upholding honesty and transparency in all our dealings, ensuring fair practices and genuine relationships.</p>
            </div>
        </div>

        <div class="col-lg-4 col-md-6">
            <div class="value-card">
                <i class="bi bi-lightbulb"></i>
                <h6>Innovation</h6>
                <p>Continuously seeking creative solutions and embracing new technologies to enhance the user experience.</p>
            </div>
        </div>

        <div class="col-lg-4 col-md-6">
            <div class="value-card">
                <i class="bi bi-star"></i>
                <h6>Quality</h6>
                <p>Committed to excellence in every product and experience offered on our platform.</p>
            </div>
        </div>

        <div class="col-lg-4 col-md-6">
            <div class="value-card">
                <i class="bi bi-globe"></i>
                <h6>Accessibility</h6>
                <p>Ensuring our platform is inclusive and easy to use for everyone.</p>
            </div>
        </div>

    </div>
</section>