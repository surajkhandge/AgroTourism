<script>
    document
        .getElementById("citySearchBox")
        .addEventListener("input", function () {

            this.value =
                this.value
                    .replace(/[^a-zA-Z\s]/g, '');

        });
    let selectedCityId = 0;
    let currentIndex = -1;

    $(document).ready(function () {

        let today = new Date();

        $('#checkinDate').datepicker({
            format: 'dd-mm-yyyy',
            autoHide: true,
            startDate: today
        }).on('change', function () {

            let checkIn = $(this).datepicker('getDate');

            $('#checkoutDate').datepicker('setStartDate', checkIn);

        });

        $('#checkoutDate').datepicker({
            format: 'dd-mm-yyyy',
            autoHide: true,
            startDate: today
        });

        // CITY SUGGESTION
        $("#citySearchBox").on("input", function () {

            let value = $(this).val();

            if (value.length < 2) {
                $("#citySuggestions").hide();
                return;
            }

            $.ajax({
                url: '/Visitor/CitySuggestionSK',
                type: 'GET',
                data: { prefix: value },

                success: function (data) {

                    $("#citySuggestions").empty();

                    $.each(data, function (i, city) {

                        $("#citySuggestions").append(
                            "<div class='suggestion-item' data-id='" + city.CityId + "'>" +
                            city.CityName +
                            "</div>"
                        );

                    });

                    $("#citySuggestions").show();
                }
            });

        });

        // SELECT CITY
        $(document).on("click", ".suggestion-item", function () {

            $("#citySearchBox").val($(this).text());
            selectedCityId = $(this).data("id");

            $("#citySuggestions").hide();
        });

        // ARROW KEY SUPPORT
        $("#citySearchBox").keydown(function (e) {

            let items = $(".suggestion-item");

            if (!items.length) return;

            if (e.key === "ArrowDown") {
                currentIndex++;
            }

            if (e.key === "ArrowUp") {
                currentIndex--;
            }

            if (currentIndex >= items.length) currentIndex = 0;
            if (currentIndex < 0) currentIndex = items.length - 1;

            items.removeClass("active");
            items.eq(currentIndex).addClass("active");

            if (e.key === "Enter") {

                $("#citySearchBox").val(items.eq(currentIndex).text());
                selectedCityId = items.eq(currentIndex).data("id");

                $("#citySuggestions").hide();
            }

        });

        // SEARCH BUTTON
        $("#mainSearchBtn").click(function () {

            let checkinRaw = $("#checkinDate").val();
            let checkoutRaw = $("#checkoutDate").val();

            if (selectedCityId == 0) {

                showToast("Please select destination", "error");

                return;

            }

            if (checkinRaw == "" || checkoutRaw == "") {

                showToast("Please select check-in & check-out date", "warning");

                return;

            }

            function convertDate(d) {

                let parts = d.split("-");

                return parts[2] + "-" + parts[1] + "-" + parts[0];

            }

            let checkin = convertDate(checkinRaw);
            let checkout = convertDate(checkoutRaw);

            showLoading(
                "Searching farms",
                "Finding best stays for you..."
            );

            setTimeout(() => {

                window.location.href =
                    "/Visitor/SearchResultSK?cityId=" + selectedCityId +
                    "&checkin=" + checkin +
                    "&checkout=" + checkout;

            }, 800);

        });   // click close

    });   // ⭐ document.ready close (ADD THIS)

    $(document).click(function (e) {

        if (!$(e.target)
            .closest(".search-item")
            .length) {

            $("#citySuggestions").hide();

        }

    });

</script>
<script>
function toggleWishlist(btn) {

    let farmhousecode = btn.getAttribute("data-farm");

    var isLoggedIn = '@(Session["VisitorCode"] != null ? "true" : "false")';

    // login check
    if (isLoggedIn === "false") {

        var loginModal = new bootstrap.Modal(
            document.getElementById('login-modal')
        );
        loginModal.show();

        return;
    }

    // remove wishlist
    if (btn.classList.contains("active")) {

        $.ajax({
            url: '/Visitor/RemoveFromWishlistSK',
            type: 'POST',
            data: { farmhousecode: farmhousecode }
        });

        btn.classList.remove("active");
        btn.querySelector("i").classList.replace("bi-heart-fill", "bi-heart");
        showToast("Removed from wishlist", "error");

    }

    // add wishlist
    else {

        $.ajax({
            url: '/Visitor/AddToWishlistSK',
            type: 'POST',
            data: { farmhousecode: farmhousecode }
        });

        btn.classList.add("active");
        btn.querySelector("i").classList.replace("bi-heart", "bi-heart-fill");
        showToast("Added to wishlist", "success");
    }
}

    function addOrRemoveWishlist(btn, farmhousecode) {

        if (btn.classList.contains("active")) {

            fetch('/Visitor/RemoveFromWishlistSK', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ farmhousecode: farmhousecode })
            });

            btn.classList.remove("active");
            btn.querySelector("i").classList.replace("bi-heart-fill", "bi-heart");
            showToast("Removed from wishlist", "error");

        } else {

            fetch('/Visitor/AddToWishlistSK', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ farmhousecode: farmhousecode })
            });

            btn.classList.add("active");
            btn.querySelector("i").classList.replace("bi-heart", "bi-heart-fill");
            showToast("Added to wishlist", "success");
        }
    }

    window.addEventListener("scroll", function () {

        let nav = document.getElementById("mainNavbar");

        if (window.scrollY > 50) {

            nav.classList.add("navbar-scrolled");

        }
        else {

            nav.classList.remove("navbar-scrolled");

        }

    });
</script>
@*sweetalerts&toasters*@
<script>
    function showLoading(title, message) {

        Swal.fire({

            title: title,

            html: `

<div class="modern-loader">

<div class="loader-ring"></div>

<div class="loader-title">
${title}
</div>

<div class="loader-text">
${message}
<span class="dots"></span>
</div>

</div>
`,

            showConfirmButton: false,
            allowOutsideClick: false,
            background: "#ffffff",
            width: 400

        });

    }
    function showToast(message, type = "info") {

        let container = document.getElementById("toastContainer");

        let toast = document.createElement("div");

        toast.className = "custom-toast toast-" + type;

        let icon = "fa-circle-info";

        if (type === "success") icon = "fa-check";
        if (type === "error") icon = "fa-xmark";
        if (type === "warning") icon = "fa-exclamation";

        toast.innerHTML = `

<div class="toast-icon">

<i class="fa-solid ${icon}"></i>

</div>

<div>

${message}

</div>

<div class="toast-close">

<i class="fa-solid fa-xmark"></i>

</div>

<div class="toast-progress"></div>

`;

        container.appendChild(toast);

        setTimeout(() => {

            toast.style.opacity = "0";

            setTimeout(() => {
                toast.remove();
            }, 300);

        }, 3000);

        toast.querySelector(".toast-close").onclick = function () {

            toast.remove();

        }

    }
    function goToCity(url) {

        showLoading(
            "Loading destination",
            "Opening farm listings..."
        );

        setTimeout(function () {

            window.location.href = url;

        }, 800);

    }

    function openFarm(url) {

        showLoading(
            "Loading farm",
            "Opening farm details..."
        );

        // minimum 1 second loader
        setTimeout(function () {

            window.location.href = url;

        }, 1000);

    }
    document.querySelectorAll('.stat-num').forEach(counter => {

        let target = parseFloat(counter.getAttribute('data-target'));

        let count = 0;

        let speed = target / 50;

        let update = () => {

            if (count < target) {

                count += speed;

                counter.innerText = Math.floor(count);

                requestAnimationFrame(update);

            }
            else {

                counter.innerText = target;

            }

        };

        update();

    });
</script>
