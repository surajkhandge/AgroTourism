@{
    Layout = "~/Views/Shared/Visitor.cshtml";
}
@{
    ViewBag.Title = "Payment Success";
}
<div class="container mt-5">
    <div class="row g-4">

        <div class="col-md-8">

            <div class="card shadow-lg border-0 rounded-4 p-4">

                <div class="text-center">

                    <div class="success-icon mb-3">
                        <i class="bi bi-check-circle-fill"></i>
                    </div>

                    <h2 class="fw-bold text-success">
                        Payment Successful
                    </h2>

                    <p class=" text-muted">
                        Your Booking payment has been processed successfully.
                    </p>
                </div>
                <hr />
                <div class="row text-center">

                    <div class="col-md-4">
                        <p class="text-muted">Transcation Id</p>
                        <strong>@ViewBag.PaymentId</strong>
                    </div>
                    <div class="col-md-4">
                        <p class="text-muted">Amount Paid</p>
                        <strong>@ViewBag.Amount</strong>
                    </div>
                    <div class="col-md-4">
                        <p class="text-muted">Date</p>
                        <strong>@ViewBag.DateTime</strong>
                    </div>
                </div>

                <div class="text-center mt-4">

                    <a href="/Visitor/ViewInvoiceST" target="_blank"
                       class="btn btn-outline-dark me-3">
                        View Booking Invoice
                    </a>

                    <a href="/Visitor/DownloadInvoiceST"
                       class="btn btn-outline-dark me-3">
                        Dowload Invoice
                    </a>

                    <a href="/Visitor/MyBookingsTP"
                       class="btn btn-success">
                        Go to Booking Records
                    </a>
                </div>

            </div>

        </div>
        <div class="col-md-4">
            <div class="card shadow-sm p-4 border-0 rounded-4">

                <h5 class="fw-bold mb-3">
                    Booking Summary
                </h5>
                <p class="text-muted mb-1">Farmhouse</p>
                <strong>@ViewBag.FarmHouse</strong>

                <hr />

                <p class="text-muted mb-1">Visiting Dates</p>

                <strong>
                    @ViewBag.CheckinDate - @ViewBag.CheckoutDate
                </strong>

                <hr />

                <p class="text-muted mb-1">Guests</p>
                <strong>@ViewBag.NoOfGuest</strong>

                <hr />

                <p class="text-muted mb-1">Total Payable</p>

                <h4 class="text-success fw-bold">
                    &#8377; @string.Format("{0:N0}", @ViewBag.Amount)
                </h4>

            </div>
        </div>
    </div>
</div>
<style>
    .success-icon {
        width: 90px;
        height: 90px;
        border-radius: 50%;
        background: #e8f5e9;
        color: #198754;
        font-size: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: auto;
    }
</style>