<!-- Bootstrap -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet" />
<style>
    /* =========================
       FARM CARD STYLE (HOME STYLE)
    ========================= */

    .farm-card {
        border-radius: 18px;
        overflow: hidden;
        background: #fff;
        transition: all 0.3s ease;
    }

        .farm-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.08);
        }

    /* IMAGE WRAPPER */
    .image-wrapper {
        position: relative;
        overflow: hidden;
    }

        .image-wrapper img {
            height: 220px;
            width: 100%;
            object-fit: cover;
            transition: 0.4s ease;
        }

    .farm-card:hover .image-wrapper img {
        transform: scale(1.05);
    }

    /* WISHLIST BUTTON (White Circle Top Right) */
    .wishlist-btn {
        position: absolute;
        top: 12px;
        right: 12px;
        background: #fff;
        border: none;
        width: 34px;
        height: 34px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        cursor: pointer;
        transition: 0.3s;
    }

        .wishlist-btn i {
            font-size: 16px;
            color: #555;
        }

        .wishlist-btn.active i {
            color: red;
        }

    /* RATING BADGE (ORANGE LIKE 2ND IMAGE) */
    .rating-badge {
        position: absolute;
        bottom: 12px;
        right: 12px;
        background: #f4a100;
        color: #fff;
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 14px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 5px;
    }

        .rating-badge i {
            font-size: 13px;
        }

    /* CARD BODY */
    .card-body {
        padding: 18px;
    }

    .card-title {
        font-size: 18px;
        color: #1e2a28;
    }

    /* PRICE STYLE (ORANGE) */
    .price-text {
        font-size: 18px;
        font-weight: 700;
        color: #f4a100;
    }

    /* VIEW DETAILS BUTTON (Outlined Green Like Image 2) */
    .view-btn {
        border: 2px solid #2f5d50;
        color: #2f5d50;
        border-radius: 25px;
        padding: 6px 18px;
        font-weight: 500;
        transition: 0.3s ease;
        background: transparent;
    }

        .view-btn:hover {
            background: #2f5d50;
            color: #fff;
        }
</style>
<div id="toastContainer" class="toast-container"></div>
<section class="sect1">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end mb-4">
            <h2 class="h2 fw-bold mb-0"> Choose Farmhouses</h2>
        </div>
        <div class="row g-4">

            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4 d-flex">

                    <div class="card w-100 border-0 farm-card">

                        <!-- IMAGE WRAPPER -->
                        <div class="image-wrapper">

                            <img class="card-img-top img-fluid"
                                 src="https://images.unsplash.com/photo-1567688040542-d9a5d079b7c0"
                                 style="height:220px; object-fit:cover;" />

                            <!-- Wishlist -->
                            <button class="wishlist-btn"
                                    data-farm="@item.FarmHouseCode"
                                    onclick="toggleWishlist(this)">
                                <i class="bi bi-heart"></i>
                            </button>

                            <!-- Rating Badge -->
                            <div class="rating-badge">
                                <i class="bi bi-star-fill"></i>
                                @item.AvgRating
                            </div>

                        </div>

                        <!-- BODY -->
                        <div class="card-body d-flex flex-column">

                            <h5 class="card-title fw-bold mb-1">
                                @item.FarmHouseName
                            </h5>

                            <p class="text-muted small mb-3">
                                @item.CityName
                            </p>

                            <div class="d-flex justify-content-between align-items-center mt-auto">

                                <div>
                                    <span class="price-text">
                                        ₹@item.LowestPrice
                                    </span>
                                    <small class="text-muted"> / night</small>
                                </div>

                                <a class="btn view-btn" onclick="openFarm('@Url.Action("FarmDetailsSK","Visitor", new { id = item.FarmHouseCode })')">
                                    View Details
                                </a>

                            </div>

                        </div>

                    </div>

                </div>
            }
        </div>
    </div>
</section>
@Scripts.Render("~/bundles/jquery")
@Scripts.Render("~/bundles/bootstrap")
<script>
    function toggleWishlist(btn) {

    let farmhousecode = btn.getAttribute("data-farm");

    var isLoggedIn = '@(Session["VisitorCode"] != null ? "true" : "false")';

    // login check
    if (isLoggedIn === "false") {

        var loginModal = new bootstrap.Modal(
            document.getElementById('login-modal')
        );
        loginModal.show();

        return;
    }

    // remove wishlist
    if (btn.classList.contains("active")) {

        $.ajax({
            url: '/Visitor/RemoveFromWishlistSK',
            type: 'POST',
            data: { farmhousecode: farmhousecode }
        });

        btn.classList.remove("active");
        btn.querySelector("i").classList.replace("bi-heart-fill", "bi-heart");

        showToast("Removed from wishlist", "error");

    }

    // add wishlist
    else {

        $.ajax({
            url: '/Visitor/AddToWishlistSK',
            type: 'POST',
            data: { farmhousecode: farmhousecode }
        });

        btn.classList.add("active");
        btn.querySelector("i").classList.replace("bi-heart", "bi-heart-fill");

        showToast("Added to wishlist", "success");
    }
}

    function addOrRemoveWishlist(btn, farmhousecode) {

        if (btn.classList.contains("active")) {

            fetch('/Visitor/RemoveFromWishlistSK', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ farmhousecode: farmhousecode })
            });

            btn.classList.remove("active");
            btn.querySelector("i").classList.replace("bi-heart-fill", "bi-heart");

            showToast("Removed from wishlist", "error");

        } else {

            fetch('/Visitor/AddToWishlistSK', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ farmhousecode: farmhousecode })
            });

            btn.classList.add("active");
            btn.querySelector("i").classList.replace("bi-heart", "bi-heart-fill");

            showToast("Added to wishlist", "success");
        }
    }

    @*sweetalerts&toasters*@
    function showLoading(title, message) {

        Swal.fire({

            title: title,

            html: `

<div class="modern-loader">

<div class="loader-ring"></div>

<div class="loader-title">
${title}
</div>

<div class="loader-text">
${message}
<span class="dots"></span>
</div>

</div>
`,

            showConfirmButton: false,
            allowOutsideClick: false,
            background: "#ffffff",
            width: 400

        });

    }
    function showToast(message, type = "info") {

        let container = document.getElementById("toastContainer");

        let toast = document.createElement("div");

        toast.className = "custom-toast toast-" + type;

        let icon = "fa-circle-info";

        if (type === "success") icon = "fa-check";
        if (type === "error") icon = "fa-xmark";
        if (type === "warning") icon = "fa-exclamation";

        toast.innerHTML = `

<div class="toast-icon">

<i class="fa-solid ${icon}"></i>

</div>

<div>

${message}

</div>

<div class="toast-close">

<i class="fa-solid fa-xmark"></i>

</div>

<div class="toast-progress"></div>

`;

        container.appendChild(toast);

        setTimeout(() => {

            toast.style.opacity = "0";

            setTimeout(() => {
                toast.remove();
            }, 300);

        }, 3000);

        toast.querySelector(".toast-close").onclick = function () {

            toast.remove();

        }

    }
    function openFarm(url) {

        showLoading(
            "Loading farm",
            "Opening farm details..."
        );

        // minimum 1 second loader
        setTimeout(function () {

            window.location.href = url;

        }, 1000);

    }
</script>