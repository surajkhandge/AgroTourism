                    </div>
                </div>

                <div class="col-md-2">
                    <button class="btn btn-primary w-100">
                        <i class="fa fa-search"></i> Search
                    </button>
                </div>

            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <h1><strong>Use This Toaster</strong></h1>
            <div class="toast-demo">

                <button onclick="showToast('This is a Normal Toast','default')" class="btn btn-secondary btn-rounded">default</button>

                <button onclick="showToast('Success Toast','success')" class="btn btn-success btn-rounded">success</button>

                <button onclick="showToast('Error Toast','error')" class="btn btn-danger btn-rounded">error</button>

                <button onclick="showToast('Warning Toast','warning')" class="btn btn-warning btn-rounded">warning</button>

                <button onclick="showToast('Information Toast','info')" class="btn btn-info btn-rounded">info</button>

                <button onclick="showToast('Loading Toast','loading')" class="btn btn-dark btn-rounded">loading</button>

            </div>
        </div>
    </div>
    <div class="card mb-3">
        <div class="card-body">
            <h1><strong>Use This SweetAlerts</strong></h1>
            <div class="alert-demo mt-4">

                <button class="btn btn-secondary" onclick="showAlert('default')">default</button>

                <button class="btn btn-success" onclick="showAlert('success')">success</button>

                <button class="btn btn-danger" onclick="showAlert('error')">error</button>

                <button class="btn btn-warning" onclick="showAlert('warning')">warning</button>

                <button class="btn btn-info" onclick="showAlert('info')">info</button>

                <button class="btn btn-dark" onclick="showAlert('loading')">loading</button>

            </div>
        </div>
    </div>

    <div id="toastContainer" class="toast-container"></div>



