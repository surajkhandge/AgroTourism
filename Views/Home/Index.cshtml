@model AgroClassLib.FarmOwner.LoginRS

@{
    ViewBag.Title = "Login";
    //Layout = "~/Views/Shared/_Layout.cshtml";
    Layout = null;
}
<!-- Bootstrap CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

<!-- Bootstrap Icons -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />

<!-- FontAwesome -->
<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
<!-- jQuery -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<style>
    body {
        /*        background: linear-gradient(135deg, #667eea, #764ba2);*/

        background-image: url('@Url.Content("~/content/img/loginscreen.png")');
/*        background-image: url('../../');*/
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
    }

    .login-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: flex-end;
        padding-right: 150px;
        position: relative;
        z-index: 2;
    }

    .login-card {
        border-radius: 20px;
        padding: 40px;
        /* GLASS EFFECT */

        background: rgba(255,255,255,0.15);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.3);
        box-shadow: 0 20px 50px rgba(0,0,0,0.25);
        color: white;
    }
    /*
        .login-card:hover {
            transform: translateY(-5px);
        }*/

    .form-control {
        border-radius: 10px;
        background: rgba(255,255,255,0.25);
        border: 1px solid rgba(255,255,255,0.4);
        color: white;
    }

        .form-control::placeholder {
            color: #eee;
        }

        .form-control:focus {
            background: rgba(255,255,255,0.35);
            box-shadow: none;
            color: white;
        }
    .login-card h3 {
        color: white;
    }
    .hero-text {
        position: absolute;
        left: 80px;
        top: 50%;
        transform: translateY(-50%);
        color: white;
        z-index: 2;
    }

        .hero-text h1 {
            font-size: 55px;
            font-weight: 700;
        }

        .hero-text p {
            font-size: 20px;
            opacity: 0.9;
        }
    body::before {
        content: "";
        position: absolute;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.35);
        top: 0;
        left: 0;
    }

    .btn-login {
        border-radius: 10px;
        font-weight: 600;
        background: linear-gradient(90deg,#11998e,#38ef7d);
        border: none;
        transition: 0.3s;
    }

        .btn-login:hover {
            opacity: 0.9;
        }

    .link-style {
        font-size: 14px;
    }

    .forgot-btn {
        display: inline-block;
        padding: 8px 18px;
        border-radius: 30px;
        background: linear-gradient(90deg,#ff416c,#ff4b2b);
        color: white;
        text-decoration: none;
        font-size: 14px;
        transition: 0.3s;
    }

        .forgot-btn:hover {
            transform: scale(1.05);
            color: white;
        }

    .create-owner {
        display: inline-block;
        padding: 10px 20px;
        border-radius: 30px;
        background: linear-gradient(90deg,#2193b0,#6dd5ed);
        color: white;
        text-decoration: none;
        margin-right: 10px;
        transition: 0.3s;
    }

        .create-owner:hover {
            transform: scale(1.05);
            color: white;
        }

    .create-visitor {
        display: inline-block;
        padding: 10px 20px;
        border-radius: 30px;
        background: linear-gradient(90deg,#f7971e,#ffd200);
        color: black;
        text-decoration: none;
        transition: 0.3s;
    }

        .create-visitor:hover {
            transform: scale(1.05);
        }
</style>

<div class="container-fluid login-wrapper d-flex justify-content-end align-items-center">
    <div class="col-md-3 ">
        <div class="login-card">

            <h3 class="text-center mb-4 fw-bold">Welcome Back 👋</h3>

            @if (ViewBag.Message != null)
            {
                <div class="alert alert-danger text-center">
                    @ViewBag.Message
                </div>
            }

            @using (Html.BeginForm("Login", "Home", FormMethod.Post))
            {
                <div class="mb-3">
                    <label>Email</label>
                    @Html.TextBoxFor(m => m.UserEmail,
                        new
                        {
                            @class = "form-control",
                            placeholder = "Enter Email",
                            autocomplete = "off"
                        })
                    @Html.ValidationMessageFor(m => m.UserEmail, "", new { @class = "text-danger" })
                </div>

                <div class="mb-3">
                    <label>Password</label>
                    @Html.PasswordFor(m => m.UserPassword,
                        new
                        {
                            @class = "form-control",
                            placeholder = "Enter Password",
                            autocomplete = "new-password"
                        })
                    @Html.ValidationMessageFor(m => m.UserPassword, "", new { @class = "text-danger" })
                </div>

                <button type="submit" class="btn btn-login w-100 text-white">
                    Login
                </button>

                <div class="text-center mt-3">
                    <a href="@Url.Action("ForgotPassword","FarmOwner")"
                       class="forgot-btn">
                        🔒 Forgot Password?
                    </a>
                </div>

                <hr />

                <div class="text-center mt-4">
                    <p class="fw-bold mb-3">Create Account As</p>

                    <a href="@Url.Action("Register","FarmOwner")"
                       class="create-owner">
                        Farm Owner
                    </a>

                    <a href="@Url.Action("VisitorRegistrationVH","Visitor")"
                       class="create-visitor">
                        Visitor
                    </a>
                </div>
            }

        </div>
    </div>
</div>

@section Scripts {

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    @*@Scripts.Render("~/bundles/jqueryval")*@
}
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    function showForgot() {
        var x = document.getElementById("forgotDiv");
        if (x.style.display === "none") {
            x.style.display = "block";
        } else {
            x.style.display = "none";
        }
    }
</script>



