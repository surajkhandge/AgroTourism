    //            }
    //        }
    //    });
    //}

    function showForgott() {
        $("#loginForm").hide();
        $("#forgotForm").show();
    }

    function showLogin() {

        $("#forgotForm").hide();
        $("#loginForm").show();

        // reset send otp button
        $("#sendOtpBtn").prop("disabled", false);
        $("#sendOtpBtn").text("Send OTP");

        // clear email
        $("#forgotEmail").val("");
    }
    function showForgot() {

        if (otpTimerInterval) {
            clearInterval(otpTimerInterval);
        }

        $("#otpForm").hide();
        $("#loginForm").show();

        $("#forgotForm").hide();


        $("#forgotEmail").val("");
        $("#otp").val("");
        $("#newPassword").val("");
        $("#confirmPassword").val("");


        $("#sendOtpBtn").prop("disabled", false);
        $("#sendOtpBtn").text("Send OTP");


    }
    window.history.pushState(null, null, window.location.href);
    window.onpopstate = function () {
        window.location.href = '/FarmOwner/Logout';
    };
</script>
