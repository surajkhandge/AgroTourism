<div class="main-container">

    <!-- LEFT -->
    <div class="left-panel">
        <div class="left-card">
            <h2>AgroFarm</h2>
            <p>Smart Farming Solutions</p>
            <h1>Welcome Back, Farmer!</h1>
            <p>Manage your farm, track crops, and get insights all in one place.</p>
        </div>
    </div>

    <!-- RIGHT -->
    <div class="right-panel">
        <div class="login-card">

            <div id="loginForm">
                <h2 class="text-center mb-2">Welcome Back <i class="fa-solid fa-leaf"></i></h2>
                <p>Sign in to continue to your farm</p>

                @using (Html.BeginForm("LoginRS", "FarmOwner", FormMethod.Post, new { autocomplete = "off" }))
                {
                    <!-- EMAIL -->
                    <div class="form-group">
                        <label>Email</label>
                        <div class="input-wrapper">
                            @Html.TextBoxFor(m => m.UserEmail, new
                       {
                           @class = "form-control" + (ViewData.ModelState["UserEmail"]?.Errors.Any() == true ? " input-validation-error" : ""),
                           placeholder = "name@example.com",
                           id = "email",
                           required = "required",
                           type = "email"
                       })
                            @Html.ValidationMessageFor(m => m.UserEmail, "", new { @class = "text-danger" })
                        </div>
                    </div>


                    <!-- PASSWORD WITH EYE ICON -->
                    <div class="form-group">
                        <label>Password</label>
                        <div class="input-wrapper password-field">
                            @Html.TextBoxFor(m => m.UserPassword, new

                            {
                                               @class = "form-control" + (ViewData.ModelState["UserPassword"]?.Errors.Any() == true ? " input-validation-error" : ""),
                                               placeholder = "Enter your password",
                                               id = "password",
                                               //autocomplete = "new-password",
                                               autocomplete = "off",
                                               required = "required"
                                           })
                            <span class="eye-icon" onclick="togglePassword()">
                                <i class="fa-regular fa-eye" id="toggleIcon"></i>
                            </span>
                            @Html.ValidationMessageFor(m => m.UserPassword, "", new { @class = "text-danger" })
                        </div>
                    </div>



                    <button type="submit" class="btn-login">Login</button>

                    <div class="text-center mt-2">
                        <a href="javascript:void(0)" class="forgot-btn" onclick="showForgott()">Forgot Password?</a>
                    </div>
                }

                <div class="text-center mt-4">
                    <p>Create Account As</p>

                    <!-- 🔥 ADD THIS WRAPPER -->
                    <div class="create-account-buttons">
                        <a href="@Url.Action("Register","FarmOwner")" class="create-owner">Farm Owner</a>
                        <a href="@Url.Action("VisitorRegistrationVH","Visitor")" class="create-visitor">Visitor</a>
                    </div>

                </div>
            </div>

            <!-- Forgot -->
            <div id="forgotForm" style="display:none">
                <h3 class="text-center mb-3">Forgot Password</h3>
                <input type="email" id="forgotEmail" class="form-control" placeholder="Enter your registered email" autocomplete="off" required>

                <button type="button" id="sendOtpBtn" onclick="sendOTP()" class="btn btn-warning w-100">
                    Send OTP
                </button>
                <div class="text-center mt-2">
                    <a href="#" onclick="showLogin()">Back</a>
                </div>
            </div>

            <!-- OTP -->
            <div id="otpForm" style="display:none">
                <h3 class="text-center mb-4">Verify OTP</h3>

                <!-- Timer Display -->
                <div class="text-center mb-3">
                    <span id="otpTimer" style="font-size: 18px; color: #ff416c; font-weight: bold;">05:00</span>
                    <small style="color: #666;"> minutes remaining</small>
                </div>


                <div class="form-group">
                    <label>Enter OTP</label>
                    <div class="otp-container">
                        <input type="text" maxlength="1" class="otp-box">
                        <input type="text" maxlength="1" class="otp-box">
                        <input type="text" maxlength="1" class="otp-box">
                        <input type="text" maxlength="1" class="otp-box">
                        <input type="text" maxlength="1" class="otp-box">
                        <input type="text" maxlength="1" class="otp-box">
                    </div>
                </div>
                <button type="button" onclick="verifyOTP()" class="btn btn-success w-100">
                    Verify OTP
                </button>

                <!-- Resend OTP button -->
                <div class="text-center mt-2">
                    <small>Didn't receive OTP?</small>
                    <button type="button" id="resendBtn" onclick="resendOTP()"
                            class="btn btn-link p-0 ms-1"
                            style="color:black; cursor:not-allowed;" disabled>
                        Resend OTP
                    </button>
                </div>

                <div class="text-center mt-4">
                    <a href="javascript:void(0)" onclick="showForgot()">
                        ← Back to Login
                    </a>
                </div>

            </div>

            <div id="resetForm" style="display:none">
                <h3 class="text-center mb-4">Reset Password</h3>
                <div class="form-group">
                    <label>New Password</label>
                    <input type="password" id="newPassword" class="form-control" autocomplete="new-password" required>
                </div>
                <div class="form-group">
                    <label>Confirm Password</label>
                    <input type="password" id="confirmPassword" class="form-control" autocomplete="new-password" required>
                </div>
                <button type="button" onclick="resetPassword()" class="btn btn-success w-100">
                    Update Password
                </button>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")

}

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    $(document).ready(function () {
        $("#newPassword").val("");
        $("#confirmPassword").val("");
    });

    const inputs = document.querySelectorAll(".otp-box");

    inputs.forEach((input, index) => {
        input.addEventListener("input", (e) => {
            if (e.target.value.length === 1) {
                if (index < inputs.length - 1) {
                    inputs[index + 1].focus();
                }
            }
        });

        input.addEventListener("keydown", (e) => {
            if (e.key === "Backspace" && input.value === "") {
                if (index > 0) {
                    inputs[index - 1].focus();
                }
            }
        });
    });


    // Toggle Password Function
    function togglePassword() {
        var pass = document.getElementById("password");
        var icon = document.getElementById("toggleIcon");

        if (pass.type === "password") {
            pass.type = "text";
            icon.classList.remove("fa-eye");
            icon.classList.add("fa-eye-slash");
        } else {
            pass.type = "password";
            icon.classList.remove("fa-eye-slash");
            icon.classList.add("fa-eye");
        }
    }
    // Timer variable
    let otpTimerInterval;

    // start Timer  function
    function startOTPTimer(duration = 300) { // 300 seconds = 5 minutes
        let timer = duration;
        const timerElement = document.getElementById('otpTimer');
        const resendBtn = document.getElementById('resendBtn');
        const resendMessage = document.getElementById('resendMessage');

        // जुना timer असेल तर clear करा
        if (otpTimerInterval) {
            clearInterval(otpTimerInterval);
        }

        // Resend button disable
        if (resendBtn) {
            resendBtn.disabled = true;
            resendBtn.style.color = '#ccc';
            resendBtn.style.cursor = 'not-allowed';
        }

        if (resendMessage) {
            resendMessage.innerHTML = 'Didn\'t receive OTP? ';
        }

        // Timer start
        otpTimerInterval = setInterval(function () {
            const minutes = Math.floor(timer / 60);
            const seconds = timer % 60;

            // Timer display update
            if (timerElement) {
                timerElement.textContent = `${minutes}:${seconds < 10 ? '0' + seconds : seconds}`;
            }

            timer--;

            // Timer end
            if (timer < 0) {
                clearInterval(otpTimerInterval);

                if (timerElement) {
                    timerElement.textContent = '00:00';
                }

                // Resend button active
                if (resendBtn) {
                    resendBtn.disabled = false;
                    resendBtn.style.color = '#ff416c';
                    resendBtn.style.cursor = 'pointer';
                }

                if (resendMessage) {
                    resendMessage.innerHTML = 'OTP expired! ';
                }

                // Sweet Alert
                Swal.fire({
                    icon: 'info',
                    title: 'OTP Expired',
                    text: 'Your OTP has expired. Please request a new one.',
                    timer: 3000,
                    showConfirmButton: false
                });
            }
        }, 1000);
    }

    function sendOTP() {

        const email = $("#forgotEmail").val();
        const btn = $("#sendOtpBtn");

        if (!email) {
            Swal.fire("Error", "Please enter email", "error");
            return;
        }

        // button disable
        btn.prop("disabled", true);
        btn.text("Sending...");

        $.ajax({
            url: '/FarmOwner/SendOTPRS',
            type: 'POST',
            data: {
                Email: email
            },
            success: function (res) {

                if (res.success) {

                    $("#forgotForm").hide();
                    $("#otpForm").show();

                    startOTPTimer(300);

                    Swal.fire({
                        icon: 'success',
                        title: 'OTP Sent',
                        text: 'Please check your email for OTP',
                        timer: 2000,
                        showConfirmButton: false
                    });

                } else {

                    // enable button again if failed
                    btn.prop("disabled", false);
                    btn.text("Send OTP");

                    Swal.fire("Error", res.message, "error");
                }
            },
            error: function () {

                btn.prop("disabled", false);
                btn.text("Send OTP");

                Swal.fire("Error", "Something went wrong", "error");
            }
        });
    }


    function verifyOTP() {
        let otp = "";
        $(".otp-box").each(function () {
            otp += $(this).val();
        });

        if (!otp) {
            Swal.fire("Error", "Please enter OTP", "error");
            return;
        }

        $.ajax({
            url: '/FarmOwner/VerifyOTPRS',
            type: 'POST',
            data: {
                otp: otp
            },
            success: function (res) {
                if (res.success) {
                    // Timer clear
                    if (otpTimerInterval) {
                        clearInterval(otpTimerInterval);
                    }

                    $("#otpForm").hide();
                    $("#resetForm").show();
                } else {
                    Swal.fire("Invalid OTP", res.message, "error");
                }
            }
        });
    }
    function resendOTP() {
        const btn = $("#resendBtn");
        const originalText = "Resend OTP";

        // 1. लगेच disable करा
        btn.prop("disabled", true);
        btn.css({
            "color": "#ccc",
            "cursor": "not-allowed"
        });

        // 2. 30 सेकंद counter सुरू करा
        let seconds = 30;
        btn.text(`Resend OTP (${seconds}s)`);

        const timer = setInterval(function () {
            seconds--;
            btn.text(`Resend OTP (${seconds}s)`);

            // 3. 30 सेकंद पूर्ण झाले की enable करा
            if (seconds <= 0) {
                clearInterval(timer);
                btn.prop("disabled", false);
                btn.css({
                    "color": "#ff416c",
                    "cursor": "pointer"
                });
                btn.text(originalText);
            }
        }, 1000);

        // 4. AJAX call (तुझा existing code)
        $.ajax({
            url: '/FarmOwner/ResendOTPRS',
            type: 'POST',
            success: function (res) {
                if (res.success) {
                    $("#otp").val("");
                    startOTPTimer(300); // 5 minute timer सुरू करा
                    Swal.fire({
                        icon: 'success',
                        title: 'OTP Resent',
                        text: 'New OTP has been sent to your email',
                        timer: 2000,
                        showConfirmButton: false
                    });
                } else {
                    Swal.fire("Error", res.message, "error");
                }
            }
        });
    }


    function resetPassword() {

        var newPass = $("#newPassword").val();
        var confirmPass = $("#confirmPassword").val();

        // 1. Empty check 🔥
        if (!newPass || !confirmPass) {
            Swal.fire("Error", "Please enter password", "error");
            return;
        }

        // 2. Length check (optional but best)
        if (newPass.length < 6) {
            Swal.fire("Error", "Password must be at least 6 characters", "error");
            return;
        }

        // 3. Match check
        if (newPass !== confirmPass) {
            Swal.fire("Error", "Passwords do not match", "error");
            return;
        }

        // 4. AJAX call
        $.ajax({
            url: '/FarmOwner/ResetPasswordRS',
            type: 'POST',
            data: {
                newPassword: newPass,
                confirmPassword: confirmPass
            },
            success: function (res) {
                if (res.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Password Updated',
                        text: 'Your password updated successfully'
                    }).then(() => {
                        location.reload();
                    });
                }
            }
        });
    }

